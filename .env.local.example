# Supabase — get these from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Never expose this client-side

# Resend — create a free account at resend.com
RESEND_API_KEY=re_...

# App
NEXT_PUBLIC_SITE_URL=https://your-domain.com   # No trailing slash
ADMIN_EMAIL=owner@yoursalon.no                  # Where booking/contact alerts go
